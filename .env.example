VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Lead email notify (local dev) ---
# Vite does NOT run `/api` routes. Pick ONE of:
# 1) Proxy (recommended): same-origin fetch('/api/...') → your deployed Vercel app
# VITE_DEV_NOTIFY_API_ORIGIN=https://your-app.vercel.app
# 2) Full URL in the browser (needs CORS on the API — enabled in repo)
# VITE_LEAD_NOTIFICATION_URL=https://your-app.vercel.app/api/send-lead-notification

# --- Owner email notifications (set in Vercel Project → Settings → Environment Variables) ---
# RESEND_API_KEY=re_...
# OWNER_NOTIFICATION_EMAIL=infomdllanscaping@gmail.com
# RESEND_FROM_EMAIL=MDL <onboarding@resend.dev>
# Use a sender/domain you verified in Resend (dashboard).
# After deploy: Vercel → Logs → filter "send-lead-notification" if emails do not arrive.
